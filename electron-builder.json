{
  "appId": "com.vadcut.app",
  "productName": "VAD-Cut",
  "copyright": "Copyright © 2025",
  "asar": true,
  "asarUnpack": [
    "node_modules/ffmpeg-static/**",
    "node_modules/sherpa-onnx/**"
  ],
  "files": [
    "electron/**",
    "renderer/**",
    "src/**",
    "node_modules/**",
    "!node_modules/electron/**",
    "!node_modules/.cache/**",
    "!**/*.map",
    "!**/*.md"
  ],
  "extraResources": [
    {
      "from": "models/",
      "to": "models/",
      "filter": ["**/*.onnx"]
    },
    {
      "from": "models/sherpa-onnx-wasm-simd-1.12.28-vad-asr-zh_en_ja_ko_cantonese-sense_voice_small/",
      "to": "models/sherpa-onnx-wasm-simd-1.12.28-vad-asr-zh_en_ja_ko_cantonese-sense_voice_small/",
      "filter": ["**/*.js", "**/*.wasm", "**/*.data"]
    }
  ],
  "directories": {
    "output": "dist"
  },
  "win": {
    "target": [
      {
        "target": "zip",
        "arch": ["x64"]
      }
    ],
    "icon": "build/icon.ico"
  }
}
