{
  "appId": "com.vadcut.app",
  "productName": "VAD-Cut",
  "afterPack": "scripts/prune-electron-locales.js",
  "copyright": "Copyright © 2025",
  "asar": true,
  "asarUnpack": [
    "node_modules/ffmpeg-static/**",
    "node_modules/sherpa-onnx-node/**",
    "vendor/sherpa-onnx-win-x64/**"
  ],
  "files": [
    "electron/**",
    "renderer/**",
    "src/**",
    "vendor/**",
    "node_modules/**",
    "!node_modules/electron/**",
    "!node_modules/sherpa-onnx-win-x64/**",
    "!node_modules/.cache/**",
    "!**/*.map",
    "!**/*.md"
  ],
  "extraResources": [
    {
      "from": "models/silero_vad.onnx",
      "to": "models/silero_vad.onnx"
    }
  ],
  "directories": {
    "output": "dist"
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "icon": "build/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": false,
    "include": "build/installer.nsh"
  }
}
